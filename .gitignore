# Jupyter Notebook checkpoints
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Local IDE files
.vscode/
.idea/

# System files
.DS_Store
Thumbs.db

# SQLite database (generated artifact — not source code)
*.db
*.db-journal
*.db-wal

# Pipeline runtime outputs (generated per-run)
logs/*
!logs/.gitkeep
rejected_rows/*
!rejected_rows/.gitkeep
pipeline_state.json

# Raw dataset (large files — not tracked in git)
Dataset/

# Power BI output data (generated by export_data.py)
powerbi_data/
